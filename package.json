{
  "name": "qa-booster-extension",
  "version": "1.0.0",
  "description": "QA效率增强Chrome插件 - 时间戳转换、二维码生成识别",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development & vite build -c vite.content.config.ts --watch --mode development",
    "build": "tsc && vite build && vite build -c vite.content.config.ts && node scripts/copy-manifest.mjs",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.8",
    "dayjs": "^1.11.10",
    "i18next": "^25.7.4",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.251",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-static-copy": "^1.0.3"
  }
}
